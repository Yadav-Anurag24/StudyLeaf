<form method="POST" class="notepad-form">
    <input 
        type="text" 
        id="title" 
        name="title" 
        class="notepad-title"
        value="<%= note.title %>"
        disabled 
    >

    <input 
    type="text" 
    id="tags" 
    name="tags" 
    class="notepad-tags" 
    placeholder="Tags (separated by commas)..."
    value="<%= (note.tags || []).join(', ') %>" 
    >
    <input type="date" id="date" name="date" value="<%= note.date %>" required
        style="background-color: var(--background-color); color: var(--text-color); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.5rem; margin-bottom: 1rem;"
    >

    <div class="editor-options">
        <label class="editor-option">
            Status:
            <select name="status" class="status-select">
                <option value="published" <%= note.status === 'published' ? 'selected' : '' %>>Published</option>
                <option value="draft" <%= note.status === 'draft' ? 'selected' : '' %>>Draft</option>
            </select>
        </label>
        <label class="editor-option">
            <input type="checkbox" name="pinned" <%= note.pinned ? 'checked' : '' %>> Pin to top
        </label>
    </div>
    
    <textarea 
        id="content" 
        name="content" 
        class="notepad-content"
    ><%= note.content %></textarea>

    <div class="editor-actions">
        <button type="submit" class="submit-btn">Update Note</button>
        <button type="button" id="deleteNoteBtn" class="delete-btn">Delete Note</button>
    </div>
</form>

<form id="hiddenDeleteForm" method="POST" action="/note/<%= slug %>/delete" style="display:none;"></form>

<script src="/scripts/editor.js"></script>
<script>
    const mde = initEditor('content');

    // Your existing delete confirmation logic (unchanged)
    const deleteNoteBtn = document.getElementById('deleteNoteBtn');
    const hiddenDeleteForm = document.getElementById('hiddenDeleteForm');

    deleteNoteBtn.addEventListener('click', function(event) {
        Swal.fire({
            title: 'Are you sure?',
            text: "This action cannot be undone!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d9534f',
            cancelButtonColor: '#555',
            confirmButtonText: 'Yes, delete it!'
        }).then((result) => {
            if (result.isConfirmed) {
                hiddenDeleteForm.submit();
            }
        });
    });
</script>