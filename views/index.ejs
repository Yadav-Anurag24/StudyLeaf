<form action="/search" method="GET" class="search-form">
    <input type="search" name="query" placeholder="Search notes..." required>
    <button type="submit">🔎</button>
</form>

<main>
    <h2>Archive</h2>
    
    <% if (notes && notes.length > 0) { %>
        <ul class="note-list">
            <% notes.forEach(note => { %>
                <li class="note-item">
                    <a href="/note/<%= note.slug %>" class="note-title">
                        <%= note.title %>
                    </a>

                    <% if (note.tags && note.tags.length > 0) { %>
                        <div class="note-tags">
                            <% note.tags.forEach(tag => { %>
                                <a href="/tags/<%= tag %>" class="tag"><%= tag %></a>
                            <% }) %>
                        </div>
                    <% } %>

                    <% if (note.date) { %>
                        <div class="note-date">
                            <%= new Date(note.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                        </div>
                    <% } %>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No notes found. create one?</p>
    <% } %>
</main>

<a href="/note/new" class="fab" title="Add New Note">+</a>