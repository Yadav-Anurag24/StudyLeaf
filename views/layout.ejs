<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <title>StudyLeaf - <%= title %></title>

    <!-- SEO & Social Sharing Meta Tags -->
    <meta name="description" content="<%= typeof description !== 'undefined' && description ? description : 'StudyLeaf — A personal learning journal for notes, ideas, and knowledge.' %>">
    <meta name="author" content="StudyLeaf">

    <!-- Open Graph (Facebook, LinkedIn, etc.) -->
    <meta property="og:title" content="StudyLeaf - <%= title %>">
    <meta property="og:description" content="<%= typeof description !== 'undefined' && description ? description : 'StudyLeaf — A personal learning journal for notes, ideas, and knowledge.' %>">
    <meta property="og:type" content="<%= typeof ogType !== 'undefined' && ogType ? ogType : 'website' %>">
    <meta property="og:site_name" content="StudyLeaf">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="StudyLeaf - <%= title %>">
    <meta name="twitter:description" content="<%= typeof description !== 'undefined' && description ? description : 'StudyLeaf — A personal learning journal for notes, ideas, and knowledge.' %>">

    <!-- RSS Feed Autodiscovery -->
    <link rel="alternate" type="application/rss+xml" title="StudyLeaf RSS Feed" href="/feed">

    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png">


    
</head>
<body>
    <script src="https://unpkg.com/easymde/dist/easymde.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>

    <div class="container">
        <header class="site-header">
            <div class="site-branding">
                <a href="/" class="site-title">StudyLeaf</a>
                <p class="site-description">My personal learning journal.</p>
            </div>
            <nav>
                <a href="/">Home</a>
                <a href="/tags">Tags</a>
                <a href="/about">About</a>
                <button id="theme-toggle" class="theme-toggle"><i data-lucide="moon"></i></button>
            </nav>
        </header>

        <%- body %>

        <% if (typeof flashSuccess !== 'undefined' && flashSuccess.length > 0) { %>
            <div class="flash-toast flash-success" id="flashToast"><%= flashSuccess[0] %></div>
        <% } %>
        <% if (typeof flashError !== 'undefined' && flashError.length > 0) { %>
            <div class="flash-toast flash-error" id="flashToast"><%= flashError[0] %></div>
        <% } %>

    </div>

    <script>hljs.highlightAll();</script>
    <script src="/scripts/main.js"></script>
    <button id="scrollTopBtn" title="Go to top"><i data-lucide="arrow-up"></i></button>
    <script>lucide.createIcons();</script>
</body>
</html>