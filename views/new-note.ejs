<form action="/note/new" method="POST" class="notepad-form">
    <input 
        type="text" 
        id="title" 
        name="title" 
        class="notepad-title"
        placeholder="Note Title..." 
        required
    >
    <input 
    type="text" 
    id="tags" 
    name="tags" 
    class="notepad-tags" 
    placeholder="Tags (separated by commas)..."
    >

    <textarea 
        id="content" 
        name="content" 
        class="notepad-content"
    ></textarea>
    
    <div class="editor-actions">
        <button type="submit" class="submit-btn">Save Note</button>
    </div>
</form>

<script>
    const mde = new EasyMDE({
        element: document.getElementById('content'),
        spellChecker: false,
        status: false,
        // Add our custom button to the toolbar
        toolbar: [
            "bold", "italic", "strikethrough", "|", 
            "heading-1", "heading-2", "heading-3", "|", 
            "quote", "unordered-list", "ordered-list", "|", 
            "link", "image", "|", 
            {
                name: "highlight",
                action: function(editor) {
                    const cm = editor.codemirror;
                    const selection = cm.getSelection();
                    cm.replaceSelection(`<mark>${selection}</mark>`);
                },
                className: "fa fa-paint-brush", // Font Awesome icon
                title: "Highlight Text",
            },
            "|",
            "preview", "side-by-side", "fullscreen"
        ]
    });
</script>